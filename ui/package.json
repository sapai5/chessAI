{
  "name": "chess-ai-overlay",
  "version": "1.0.0",
  "description": "Transparent chess engine overlay",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Antigravity",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/sapai5/chessAI.git"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.chessai.overlay",
    "productName": "ChessAI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "../dist/server",
        "to": "server"
      },
      {
        "from": "../stockfish.exe",
        "to": "server/stockfish.exe"
      }
    ],
    "files": [
      "**/*",
      "!dist/**/*"
    ]
  }
}
